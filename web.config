<?xml version="1.0" encoding="utf-8"?>
<configuration>
 

  <system.web>
    <!-- 
      customErrors mode="Off" disables friendly error messages and displays 
      detailed ASP.NET errors (Yellow Screen of Death) to all visitors.
    -->
    <customErrors mode="Off" />
  </system.web>


  <system.webServer>
  
    <!-- Enable WebSockets -->
    <webSocket enabled="true" />

    <!-- IISNode handler -->
    <handlers>
      <add name="iisnode" path="dist/index.js" verb="*" modules="iisnode"   />
    </handlers>

    <!-- URL Rewrite rules -->
    <rewrite>
      <rules>
 
        <!-- Static files -->
        <rule name="StaticFiles" stopProcessing="false">
          <match url="^.*\.(html|js|css|png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|map|json|txt|webmanifest)$" />
          <action type="None" />
        </rule>

        <!-- WebSocket endpoints -->
        <rule name="WebSocketScoreboard" stopProcessing="true">
          <match url="^api/v1/ws$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <rule name="WebSocketPlayByPlay" stopProcessing="true">
          <match url="^api/v1/ws/(.+)/playbyplay$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- Logos -->
        <rule name="Logos" stopProcessing="true">
          <match url="^api/v1/team-logo/(.*)$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- API routes -->
        <rule name="APIRoutes" stopProcessing="true">
          <match url="^api/(.*)$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- Root -->
        <rule name="Root" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

        <!-- Catch-all -->
        <rule name="NodeJS" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="dist/index.js" />
        </rule>

      </rules>
    </rewrite>

    <!-- MIME types -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

    <!-- Security headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
         <add name="Access-Control-Allow-Origin" value="*" /> 
      </customHeaders>
    </httpProtocol>


      <security>
         <requestFiltering>
            <verbs allowUnlisted="true"> <!-- Set to false to deny all but listed verbs -->
               <add verb="HEAD" allowed="false" />
               <add verb="OPTIONS" allowed="false" />
               <!-- Add other verbs to deny as needed -->
            </verbs>
             <requestLimits maxQueryString="2000" />
         </requestFiltering>
      </security>

    <!-- Pass errors to Node -->
    <httpErrors existingResponse="PassThrough" />

    <!-- IISNode settings -->
    <iisnode
      loggingEnabled="true"
      devErrorsEnabled="true"
      nodeProcessCommandLine="node.exe" 
    />
    

  </system.webServer>

  <appSettings>
    <add key="NODE_ENV" value="production" />
  </appSettings>

</configuration>




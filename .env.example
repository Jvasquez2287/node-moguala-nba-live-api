# NBA API Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Database Configuration
# ============================================================================
DB_SERVER=your-sql-server-host
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_NAME=your-database-name

# ============================================================================
# Authentication & Security
# ============================================================================
# Clerk authentication configuration
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# JWT/Token validation secret
TOKEN_SECRET=your-jwt-secret-key

# ============================================================================
# Payment Processing
# ============================================================================
# Stripe configuration for subscription management
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# ============================================================================
# Push Notifications
# ============================================================================
# Expo access token for mobile push notifications
# Get your token from: https://expo.io/settings/access-tokens
EXPO_ACCESS_TOKEN=ExponentPushToken[your-token-here]

# ============================================================================
# Email Configuration
# ============================================================================
# Email service configuration for sending subscription and notification emails
# Supports: Gmail, SendGrid, Mailgun, or any SMTP provider

# SMTP Server Host (e.g., smtp.gmail.com, smtp.sendgrid.net)
EMAIL_HOST=smtp.gmail.com

# SMTP Server Port (587 for TLS, 465 for SSL)
EMAIL_PORT=587

# Email account username/email address
EMAIL_USER=your-email@gmail.com

# Email password or app-specific password
EMAIL_PASSWORD=your-app-password

# "From" address for outgoing emails
EMAIL_FROM=noreply@nba-tracker.com

# Use secure connection (true for 465, false for 587)
EMAIL_SECURE=false

# ============================================================================
# API Configuration
# ============================================================================
# API keys for third-party services
NBA_API_KEY=optional-nba-api-key

# ============================================================================
# Server Configuration
# ============================================================================
# Node environment (development, production, test)
NODE_ENV=development

# Server port
PORT=8000

# ============================================================================
# Optional: Proxy Configuration
# ============================================================================
# If your server is behind a proxy, configure it here
# PROXY_HOST=proxy.example.com
# PROXY_PORT=3128
# PROXY_USER=proxyuser
# PROXY_PASSWORD=proxypassword
